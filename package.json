{
  "name": "decision-journal",
  "version": "0.4.3",
  "description": "A local-first, fully offline, end-to-end encrypted decision journal for macOS.",
  "author": {
    "name": "Sina Meraji"
  },
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "postinstall": "electron-builder install-app-deps",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:mac:local": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac -c.mac.identity=null -c.mac.notarize=false"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3-multiple-ciphers": "^11.5.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.460.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.1",
    "smart-whisper": "^0.8.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@fontsource-variable/fraunces": "^5.1.0",
    "@fontsource/inter": "^5.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.9.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
